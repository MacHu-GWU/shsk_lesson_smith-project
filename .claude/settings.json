{
    "model": "sonnet",
    "permissions": {
        "defaultMode": "acceptEdits",
        "deny": [
        ],
        "allow": [
            "Read(========== Read Section ==========)",
            "Read(========== Write Section ==========)",
            "Write(.claude/*.md)",
            "Write(.claude/TEACHING.md)",
            "Write(.claude/skills/*/*.md)",
            "Write(.claude/skills/*/SKILL.md)",
            "Write(.claude/skills/*/references/*.md)",
            "Write(.claude/skills/*/scripts/*.py)",
            "Write(./**/*.md)",
            "Write(./README.md)",
            "Write(./README-cn.md)",
            "Write(./TICKET.md)",
            "Write(./CLAUDE.md)",
            "Write(shsk_lesson_smith/**/*.py)",
            "Write(tests/**/*.py)",
            "Write(scripts/**/*.py)",
            "Read(========== Bash Section ==========)",
            "Bash(.venv/bin/python debug/**/*.py)",
            "Bash(.venv/bin/python scripts/**/*.py)",
            "Bash(.venv/bin/python config/**/*.py)",
            "Bash(.venv/bin/python tests/**/*.py)",
            "Bash(mise *)",
            "Bash(uv *)",
            "Bash(ruff *)",
            "Read(========== Skill Section ==========)",
            "Read(========== Web Search ==========)",
            "WebSearch",
            "Read(========== Web Fetch ==========)",
            "WebFetch(domain:raw.githubusercontent.com)"
        ]
    },
    "extraKnownMarketplaces": {
        "sanhe-claude-code-plugin-marketplace": {
            "source": {
                "source": "github",
                "repo": "MacHu-GWU/sanhe_claude_code_plugin_marketplace-project",
                "ref": "0.2.1"
            }
        }
    },
    "enabledPlugins": {
        "coding-agent-docs@sanhe-claude-code-plugin-marketplace": true,
        "doc-writing-styles@sanhe-claude-code-plugin-marketplace": true
    }
}